{
  "info": {
    "name": "Zario - Reports Workflow",
    "_postman_id": "zario-report-workflow-v1",
    "description": "Manual QA collection for business reporting APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "zario_access_token", "value": "" },
    { "key": "date_from", "value": "" },
    { "key": "date_to", "value": "" }
  ],
  "item": [
    {
      "name": "1 - Overview Report",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{zario_access_token}}" }],
        "url": "{{baseUrl}}/api/v1/reports/overview?days=30"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has bookings', () => pm.expect(pm.response.json().data).to.have.property('bookings'));"] } }]
    },
    {
      "name": "2 - Revenue Report",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{zario_access_token}}" }],
        "url": "{{baseUrl}}/api/v1/reports/revenue?days=30"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has totals', () => pm.expect(pm.response.json().data).to.have.property('totals'));"] } }]
    },
    {
      "name": "3 - Booking Report",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{zario_access_token}}" }],
        "url": "{{baseUrl}}/api/v1/reports/bookings?days=30"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has status breakdown', () => pm.expect(pm.response.json().data).to.have.property('byStatus'));"] } }]
    },
    {
      "name": "4 - Customer Report",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{zario_access_token}}" }],
        "url": "{{baseUrl}}/api/v1/reports/customers"
      },
      "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));", "pm.test('Has segments', () => pm.expect(pm.response.json().data).to.have.property('segments'));"] } }]
    }
  ]
}
