{
  "info": {
    "name": "Zario - Inbox & Automation Workflow",
    "_postman_id": "zario-inbox-automation-flow-v1",
    "description": "Manual QA collection for WhatsApp inbox, conversation thread, automation rules, inbound webhook simulation, and STOP opt-out handling. Run after Auth, Business onboarding, Customer creation, and WhatsApp setup.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "zario_access_token", "value": "" },
    { "key": "customer_id", "value": "" },
    { "key": "automation_rule_id", "value": "" },
    { "key": "waba_id", "value": "1629202128185801" },
    { "key": "wa_phone_number_id", "value": "1222965920892386" },
    { "key": "wa_display_phone_number", "value": "15556503577" },
    { "key": "test_customer_wa_id", "value": "923468224143" },
    { "key": "inbound_message_id", "value": "" },
    { "key": "stop_message_id", "value": "" }
  ],
  "item": [
    {
      "name": "1 - Create Automation Rule",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{zario_access_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Business Hours Reply {{$timestamp}}\",\n  \"priority\": 1,\n  \"trigger\": {\n    \"type\": \"contains_any\",\n    \"keywords\": [\"timing\", \"hours\", \"open\"]\n  },\n  \"response\": {\n    \"text\": \"Assalam o alaikum! We are open from 10 AM to 8 PM.\"\n  },\n  \"stopProcessing\": true\n}"
        },
        "url": "{{baseUrl}}/api/v1/automation-rules"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const rule = pm.response.json().data.rule;",
              "pm.collectionVariables.set('automation_rule_id', rule._id);",
              "pm.test('Rule saved', () => pm.expect(rule._id).to.exist);"
            ]
          }
        }
      ]
    },
    {
      "name": "2 - List Automation Rules",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{zario_access_token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/automation-rules?isActive=true"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Rules array exists', () => pm.expect(pm.response.json().data.rules).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "3 - Get Automation Rule",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{zario_access_token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/automation-rules/{{automation_rule_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Rule id matches', () => pm.expect(pm.response.json().data.rule._id).to.eql(pm.collectionVariables.get('automation_rule_id')));"
            ]
          }
        }
      ]
    },
    {
      "name": "4 - Simulate Inbound Message That Triggers Automation",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('inbound_message_id', 'wamid.manual-auto-' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json().data;",
              "pm.test('Webhook processed', () => pm.expect(data.processed).to.be.greaterThan(0));",
              "pm.test('Inbound created', () => pm.expect(data.results[0].action).to.eql('created_inbound'));",
              "pm.test('Automation result exists', () => pm.expect(data.results[0].automations).to.be.an('array'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"{{waba_id}}\",\n      \"changes\": [\n        {\n          \"field\": \"messages\",\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"{{wa_display_phone_number}}\",\n              \"phone_number_id\": \"{{wa_phone_number_id}}\"\n            },\n            \"contacts\": [\n              {\n                \"profile\": { \"name\": \"Manual Automation Customer\" },\n                \"wa_id\": \"{{test_customer_wa_id}}\"\n              }\n            ],\n            \"messages\": [\n              {\n                \"from\": \"{{test_customer_wa_id}}\",\n                \"id\": \"{{inbound_message_id}}\",\n                \"timestamp\": \"{{$timestamp}}\",\n                \"type\": \"text\",\n                \"text\": { \"body\": \"What is your timing?\" }\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/v1/webhooks/whatsapp"
      }
    },
    {
      "name": "5 - Inbox - All Conversations",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{zario_access_token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/messages/inbox?status=all&limit=50"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Conversations array exists', () => pm.expect(pm.response.json().data.conversations).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "6 - Inbox - Needs Human",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{zario_access_token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/messages/inbox?status=needs_human&limit=50"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Conversations array exists', () => pm.expect(pm.response.json().data.conversations).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "7 - Conversation Thread",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{zario_access_token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/messages/conversations/{{customer_id}}?limit=50"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Messages array exists', () => pm.expect(pm.response.json().data.messages).to.be.an('array'));"
            ]
          }
        }
      ]
    },
    {
      "name": "8 - Simulate STOP Opt-Out",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('stop_message_id', 'wamid.manual-stop-' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const result = pm.response.json().data.results[0];",
              "pm.test('Customer opted out', () => pm.expect(result.action).to.eql('customer_opted_out'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"id\": \"{{waba_id}}\",\n      \"changes\": [\n        {\n          \"field\": \"messages\",\n          \"value\": {\n            \"messaging_product\": \"whatsapp\",\n            \"metadata\": {\n              \"display_phone_number\": \"{{wa_display_phone_number}}\",\n              \"phone_number_id\": \"{{wa_phone_number_id}}\"\n            },\n            \"contacts\": [\n              {\n                \"profile\": { \"name\": \"Manual Stop Customer\" },\n                \"wa_id\": \"{{test_customer_wa_id}}\"\n              }\n            ],\n            \"messages\": [\n              {\n                \"from\": \"{{test_customer_wa_id}}\",\n                \"id\": \"{{stop_message_id}}\",\n                \"timestamp\": \"{{$timestamp}}\",\n                \"type\": \"text\",\n                \"text\": { \"body\": \"STOP\" }\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/v1/webhooks/whatsapp"
      }
    },
    {
      "name": "9 - Verify Customer Opt-Out",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{zario_access_token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/customers/{{customer_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const customer = pm.response.json().data.customer;",
              "pm.test('Customer opted out if same customer_id was used', () => {",
              "  pm.expect(customer).to.have.property('whatsappOptIn');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "10 - Disable Automation Rule",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{zario_access_token}}" }
        ],
        "url": "{{baseUrl}}/api/v1/automation-rules/{{automation_rule_id}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    }
  ]
}
