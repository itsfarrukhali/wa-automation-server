{
  "info": {
    "name": "Zario — Business Module",
    "_postman_id": "zario-business-v1",
    "description": "Business module API tests for Zario.\n\nPrerequisite: Run the Auth collection first to get a valid accessToken stored in the 'zario_access_token' collection variable.\n\nAll requests use {{baseUrl}} and {{zario_access_token}} — set these in your Zario environment.\n\nOnboarding flow order: Step 1 → 2 → 3 → 4 → 5 (must run in sequence).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "zario_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "business_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "── READ ──",
      "item": [
        {
          "name": "GET My Business",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{zario_access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/business/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "business",
                "me"
              ]
            },
            "description": "Returns the full business profile for the authenticated owner."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response has business object', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.be.true;",
                  "  pm.expect(body.data.business).to.be.an('object');",
                  "  pm.expect(body.data.business).to.have.property('name');",
                  "  pm.expect(body.data.business).to.have.property('type');",
                  "  pm.expect(body.data.business).to.have.property('onboardingStep');",
                  "});",
                  "",
                  "// Save business ID for admin tests later",
                  "const biz = pm.response.json().data?.business;",
                  "if (biz?._id) pm.collectionVariables.set('business_id', biz._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Onboarding Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{zario_access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/business/onboarding/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "business",
                "onboarding",
                "status"
              ]
            },
            "description": "Returns per-step completion state for the frontend stepper UI."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Has steps array with 5 items', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.steps).to.be.an('array').with.lengthOf(5);",
                  "});",
                  "",
                  "pm.test('Each step has required fields', () => {",
                  "  const steps = pm.response.json().data.steps;",
                  "  steps.forEach(s => {",
                  "    pm.expect(s).to.have.all.keys('step', 'label', 'completed', 'current');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{zario_access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/business/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "business",
                "dashboard"
              ]
            },
            "description": "Aggregated stats for the dashboard home screen."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Has all dashboard sections', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data).to.have.property('business');",
                  "  pm.expect(data).to.have.property('plan');",
                  "  pm.expect(data).to.have.property('customers');",
                  "  pm.expect(data).to.have.property('bookings');",
                  "  pm.expect(data).to.have.property('messages');",
                  "});",
                  "",
                  "pm.test('Plan has usage info', () => {",
                  "  const plan = pm.response.json().data.plan;",
                  "  pm.expect(plan).to.have.property('current');",
                  "  pm.expect(plan).to.have.property('messagesUsed');",
                  "  pm.expect(plan).to.have.property('messagesLimit');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET Plan Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{zario_access_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/business/plan",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "business",
                "plan"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Plan has limits and usage percentages', () => {",
                  "  const plan = pm.response.json().data.plan;",
                  "  pm.expect(plan).to.have.property('limits');",
                  "  pm.expect(plan).to.have.property('usage');",
                  "  pm.expect(plan.usage).to.have.property('messageUsagePct');",
                  "  pm.expect(plan.usage).to.have.property('customerUsagePct');",
                  "  pm.expect(plan.usage.messageUsagePct).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
