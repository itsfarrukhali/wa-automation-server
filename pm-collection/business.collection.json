              "listen": "test",
              "script": {
                "exec": [
                  "// NOTE: This will return 403 unless your test user has role='admin'",
                  "// Manually set the role in MongoDB for this test",
                  "",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Has businesses array and pagination', () => {",
                  "    const data = pm.response.json().data;",
                  "    pm.expect(data.businesses).to.be.an('array');",
                  "    pm.expect(data.pagination).to.have.property('total');",
                  "    pm.expect(data.pagination).to.have.property('pages');",
                  "  });",
                  "} else {",
                  "  pm.test('Non-admin gets 403', () => pm.response.to.have.status(403));",
                  "}"
                ]
              }
            }
